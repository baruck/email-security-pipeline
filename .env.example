# Email Security Pipeline Configuration

# Layer 3: LLM Review (optional — leave empty to skip LLM review)
REVIEW_MODEL=gpt-5.5
REVIEW_API_ENDPOINT=https://api.openai.com/v1/chat/completions
REVIEW_API_KEY=

# Quarantine directory (where flagged emails are saved)
QUARANTINE_DIR=./quarantine

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Blocklist auto-update schedule (cron format)
BLOCKLIST_UPDATE_SCHEDULE=0 3 * * 1